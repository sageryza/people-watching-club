rules_version = '2';

// People Watching Club — Firestore security rules.
// Replaces the default test-mode rules (which expired 2026-06-22 and left the
// whole database open to read/edit/delete). Clients may CREATE into the public
// forms below with light validation; edits/deletes are reserved for the Admin
// SDK (Cloud Functions), which bypasses these rules.
service cloud.firestore {
  match /databases/{database}/documents {

    // Field notes — anyone may read and post (the site treats this as open to
    // all). Create-only from clients; no edits or deletes.
    match /observations/{id} {
      allow read: if true;
      allow create: if request.resource.data.body is string
                    && request.resource.data.body.size() > 0
                    && request.resource.data.body.size() < 5000;
      allow update, delete: if false;
    }

    // Events — anyone may read; only signed-in members may post (matches the
    // site, which blocks the event form unless logged in).
    match /events/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // RSVPs — anyone may submit; not publicly listable.
    match /rsvps/{id} {
      allow read: if false;
      allow create: if true;
      allow update, delete: if false;
    }

    // Newsletter / dispatch sign-ups — anyone may submit; not publicly listable.
    match /subscribers/{id} {
      allow read: if false;
      allow create: if true;
      allow update, delete: if false;
    }

    // Member profiles — each member may read and write only their own document.
    match /members/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // Everything else is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
